rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (matches auth.uid)
    // Fields:
    //   - uid: string (required, immutable) - Firebase Auth UID
    //   - email: string (required) - User email
    //   - displayName: string (optional) - User name
    //   - photoURL: string (optional) - User avatar
    //   - role: string (required) - 'explorer', 'guide', 'agency', 'admin'
    //   - phoneNumber: string (optional) - Phone number for guides
    //   - onboardingCompleted: boolean (optional) - Has completed onboarding
    //   - createdAt: timestamp (required, immutable) - Creation date
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "keylizzyraposo@gmail.com" && request.auth.token.email_verified == true));
    }
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.keys().hasOnly(['uid', 'email', 'displayName', 'photoURL', 'role', 'phoneNumber', 'onboardingCompleted', 'createdAt', 'favorites', 'bio', 'languages', 'location', 'hourlyRate']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['explorer', 'guide', 'agency', 'admin'] &&
             data.createdAt is timestamp &&
             (!('favorites' in data) || data.favorites is list) &&
             (!('bio' in data) || data.bio is string) &&
             (!('languages' in data) || data.languages is list) &&
             (!('location' in data) || data.location is string) &&
             (!('hourlyRate' in data) || data.hourlyRate is number);
    }
    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    function createdAtUnchanged() {
      return !('createdAt' in request.resource.data) || request.resource.data.createdAt == resource.data.createdAt;
    }

    // ===============================================================
    // Chat Helper Functions
    // ===============================================================
    function isParticipant(chatData) {
      return isAuthenticated() && request.auth.uid in chatData.participants;
    }
    function isValidChat(data) {
      return data.keys().hasAll(['participants']) &&
             data.participants is list &&
             data.participants.size() >= 2 &&
             (!('lastMessageTime' in data) || data.lastMessageTime is timestamp) &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('updatedAt' in data) || data.updatedAt is timestamp) &&
             (!('lastMessage' in data) || data.lastMessage is string) &&
             (!('unreadCount' in data) || data.unreadCount is map) &&
             (!('excursionId' in data) || data.excursionId is string) &&
             (!('excursionTitle' in data) || data.excursionTitle is string) &&
             (!('experienceId' in data) || data.experienceId is string) &&
             (!('experienceTitle' in data) || data.experienceTitle is string) &&
             (!('eventId' in data) || data.eventId is string) &&
             (!('eventTitle' in data) || data.eventTitle is string) &&
             (!('participantDetails' in data) || data.participantDetails is map);
    }
    function isValidMessage(data) {
      return data.keys().hasAll(['chatId', 'senderId', 'text', 'createdAt']) &&
             data.chatId is string &&
             data.senderId is string &&
             data.senderId == request.auth.uid &&
             data.text is string &&
             data.text.size() > 0 &&
             data.text.size() <= 1000 &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Excursion Helper Functions
    // ===============================================================
    function isGuide() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'guide';
    }
    function isExcursionOwner(data) {
      return isAuthenticated() && data.guideId == request.auth.uid;
    }
    function isValidExcursion(data) {
      return data.keys().hasAll(['guideId', 'title', 'description', 'price', 'createdAt']) &&
             data.guideId is string &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 100 &&
             data.description is string && data.description.size() > 0 && data.description.size() <= 2000 &&
             data.price is number && data.price >= 0 &&
             data.createdAt is timestamp &&
             (!('guideName' in data) || data.guideName is string) &&
             (!('guideAvatar' in data) || data.guideAvatar is string) &&
             (!('location' in data) || data.location is string) &&
             (!('locationId' in data) || data.locationId is string) &&
             (!('currency' in data) || data.currency is string) &&
             (!('duration' in data) || data.duration is string) &&
             (!('imageUrl' in data) || data.imageUrl is string) &&
             (!('category' in data) || data.category is string) &&
             (!('rating' in data) || data.rating is number) &&
             (!('reviewsCount' in data) || data.reviewsCount is number);
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && uidUnchanged() && (request.resource.data.role == 'explorer' || request.resource.data.role == 'guide' || request.resource.data.role == 'agency' || isAdmin());
      allow update: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && uidNotModified() && createdAtUnchanged() && (request.resource.data.role == resource.data.role || isAdmin());
      allow delete: if isAdmin();
    }

    match /chats/{chatId} {
      allow read: if isParticipant(resource.data) || isAdmin();
      allow create: if isParticipant(request.resource.data) && isValidChat(request.resource.data);
      allow update: if isParticipant(resource.data) && isParticipant(request.resource.data) && isValidChat(request.resource.data);
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isParticipant(get(/databases/$(database)/documents/chats/$(chatId)).data) || isAdmin();
        allow create: if isParticipant(get(/databases/$(database)/documents/chats/$(chatId)).data) && isValidMessage(request.resource.data);
        allow update, delete: if false; // Messages are immutable
      }
    }

    match /excursions/{excursionId} {
      allow read: if true; // Publicly readable
      allow create: if isGuide() && isExcursionOwner(request.resource.data) && isValidExcursion(request.resource.data);
      allow update: if isGuide() && isExcursionOwner(resource.data) && isExcursionOwner(request.resource.data) && isValidExcursion(request.resource.data) && createdAtUnchanged();
      allow delete: if (isGuide() && isExcursionOwner(resource.data)) || isAdmin();
    }

    match /events/{eventId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin(); // Only admins can manage events for now
    }

    match /experiences/{experienceId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin(); // Only admins can manage experiences for now
    }
  }
}
